PET_AGENT_API_URL=http://127.0.0.1:8000
PET_AGENT_NOTIFIER=console
PET_AGENT_USE_LLM=false
PET_AGENT_DEFAULT_PET_ID=2
PET_AGENT_PROACTIVE_TICKS_ENABLED=true
PET_AGENT_PROACTIVE_TICK_INTERVAL_SECONDS=600
PET_AGENT_PROACTIVE_TICK_MINUTES=10
PET_AGENT_ASSISTANT_DUE_SCAN_INTERVAL_SECONDS=30

# Create this with @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=

# Fill after messaging the bot once and reading getUpdates.
TELEGRAM_CHAT_ID=

# V1 multi-owner access gate. When set, Telegram chats in this comma-separated
# list can create/use owner-scoped pets. Leave empty for local single-user demo.
TELEGRAM_ALLOWED_OWNER_CHAT_IDS=
TELEGRAM_DEFAULT_OWNER_CHAT_ID=
TELEGRAM_DEFAULT_OWNER_DISPLAY_NAME=Default Owner
PET_FRIEND_DAILY_MESSAGE_INTERVAL_SECONDS=3600
PET_FRIEND_DAILY_MESSAGE_COOLDOWN_SECONDS=86400
PET_FRIEND_DAILY_MESSAGE_CHANCE=0.15
PET_FRIEND_DAILY_MESSAGE_MAX_PER_SCAN=1
PET_FRIEND_MEMORY_SHARE_SUGGESTION_COOLDOWN_SECONDS=21600
PET_FRIEND_MEMORY_SHARE_SUGGESTION_CHANCE=0.25

# Required when DESKTOP_PET_ASSET_PROVIDER=wan unless Cloudflare R2 is configured:
# Public URL that can serve this app's /static files to DashScope/Wan.
PET_AGENT_PUBLIC_BASE_URL=

# Optional Cloudflare R2 upload target for Wan reference images.
# When set, Wan uses the R2 public URL instead of requiring this app's /static
# path to be publicly reachable.
CLOUDFLARE_R2_ACCOUNT_ID=
# You may also paste the S3 endpoint into CLOUDFLARE_R2_ACCOUNT_ID; the app
# will extract the account id from https://<account-id>.r2.cloudflarestorage.com.
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_R2_KEY_PREFIX=agent-demo/wan

DASHSCOPE_API_KEY=
# WAN_KEY is also accepted as an alias for DASHSCOPE_API_KEY.
WAN_KEY=
WAN_VIDEO_MODEL=wan2.2-kf2v-flash
WAN_VIDEO_RESOLUTION=720P
WAN_PROMPT_EXTEND=true
